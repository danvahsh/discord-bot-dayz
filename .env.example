# Discord bot token — https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Channel ID for the live leaderboard
# Enable Developer Mode in Discord, then right-click the channel → Copy Channel ID
LEADERBOARD_CHANNEL_ID=123456789012345678

# Port this bot listens on for kill events from the DayZ mod
# Make sure this port is open/forwarded if DayZ is on a different machine
BOT_PORT=3005

# Shared secret — must match BotAPIKey in your DayZ server's config.json
# Generate something random, e.g.: openssl rand -hex 16
BOT_API_KEY=change-me-to-something-random

# Your Discord server ID — right-click the server icon → Copy Server ID
GUILD_ID=123456789012345678